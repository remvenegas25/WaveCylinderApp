@page
@model WaveCylinderApp.Pages.IndexModel

<!DOCTYPE html>
<html>
<head>
    <title>Wave-Shifted Cylinder Volume Calculator</title>
    <style>
        body {
            font-family: Arial;
            background: #f4f6f8;
            text-align: center;
            padding: 40px;
        }

        .container {
            background: white;
            padding: 25px;
            border-radius: 15px;
            width: 400px;
            margin: auto;
            box-shadow: 0px 0px 15px rgba(0,0,0,0.1);
        }

        input {
            width: 90%;
            padding: 8px;
            margin: 8px;
        }

        button {
            padding: 10px 20px;
            background: #0078D7;
            color: white;
            border: none;
            border-radius: 8px;
        }

        h1 {
            color: #333;
        }

        .result {
            margin-top: 15px;
            font-weight: bold;
            color: green;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Undulating Cylinder Volume</h1>

        <form method="post">
            <input type="number" step="any" placeholder="Base Radius (R)" asp-for="BaseRadius" required />
            <input type="number" step="any" placeholder="Amplitude (A)" asp-for="Amplitude" required />
            <input type="number" step="any" placeholder="Frequency (k)" asp-for="Frequency" required />
            <input type="number" step="any" placeholder="Height (H)" asp-for="Height" required />

            <button type="submit">Calculate Volume</button>
        </form>

        @if (Model.VolumeResult > 0)
        {
            <div class="result">
                Volume = @Model.VolumeResult.ToString("F4") cubic units
            </div>
        }
    </div>
</body>
</html>